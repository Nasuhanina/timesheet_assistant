FLASK_SECRET_KEY=change-me-to-a-random-secret
FLASK_DEBUG=0
SESSION_COOKIE_SECURE=1
MICROSOFT_CLIENT_ID=your-app-client-id
MICROSOFT_CLIENT_SECRET=your-app-client-secret
MICROSOFT_TENANT_ID=your-tenant-id-or-common
MICROSOFT_REDIRECT_URI=https://your-domain.com/auth/callback
ONEDRIVE_ROOT_PATH=/Timesheets
FRONTEND_URL=https://your-domain.com

# GCP Firestore ==============================================================
# Leave empty to auto-detect project from Application Default Credentials.
# Set FIRESTORE_EMULATOR_HOST=localhost:8080 for local dev with firestore emulator.
FIRESTORE_PROJECT_ID=
FIRESTORE_COLLECTION=tokens

# GPTBots ====================================================================
# Get API Key from: https://www.gptbots.ai -> Dashboard -> API Key
# Endpoint subdomain: e.g. "useast" for api-useast.gptbots.ai (leave empty for default)
GPTBOTS_API_KEY=
GPTBOTS_ENDPOINT=
